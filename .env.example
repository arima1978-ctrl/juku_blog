# フェーズ2: WordPress自動投稿(scripts/lib/wordpress.js)
# 事前準備:
#   1. WordPress管理画面(https://an-english.com/wp/wp-admin)で自動投稿専用ユーザーを
#      「投稿者」権限で作成する(管理者アカウントを自動化に使わない)
#   2. そのユーザーのプロフィール画面 → アプリケーションパスワード で新規発行する
# 投稿先カテゴリーIDは config/juku.yaml の wordpress.category_id で指定する
# (このサイトは教室ごとに同名カテゴリーが並ぶ構造のため、名前ではなくIDで固定)
WP_URL=https://an-english.com
WP_USERNAME=
WP_APP_PASSWORD=

# 承認時(WordPress投稿処理の前)・投稿失敗時にTelegramに通知する(任意。未設定でもエラーにはならずスキップされる)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# 通知メッセージに載せるダッシュボードのURL(未設定なら http://localhost:<PORT> が使われる)
DASHBOARD_URL=http://192.168.1.180:3002

# 競合キーワード分析(Keyword Gap Lite): Google Search Console連携
# (features.competitor_keyword_analysis.search_console_enabled=true の場合のみ使用)。
# サービスアカウント方式を採用(詳細はdocs/search_console_setup.md参照)。
# 1. GCPでサービスアカウントを作成しJSON鍵を発行する
# 2. Search Console(https://search.google.com/search-console)の「設定 > ユーザーと権限」で
#    サービスアカウントのメールアドレスを「閲覧者」として追加する
# 3. GSC_CLIENT_EMAIL/GSC_PRIVATE_KEY(JSON鍵のclient_email/private_key)をここに設定する
#    (private_keyの改行は \n のままでよい。コード側で復元する)
# 秘密鍵はこのファイル(.env)以外に絶対にコミットしないこと。ログにも出力しない。
GSC_AUTH_MODE=service_account
GSC_PROPERTY_URL=https://an-english.com/
GSC_CLIENT_EMAIL=
GSC_PRIVATE_KEY=
